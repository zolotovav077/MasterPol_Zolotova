<Window x:Class="MasterPol.WPF.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Эффект тени -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" Opacity="0.15" ShadowDepth="3" Color="#333333"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" Opacity="0.2" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#2196F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Border Margin="20" Background="White" CornerRadius="15" Padding="20" Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock x:Name="TxtWindowTitle" 
                       FontSize="24" FontWeight="Bold" 
                       Text="➕ Новый партнер"
                       Foreground="#333333"
                       Margin="0,0,0,15"/>

            <!-- Поля ввода (с прокруткой) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel>
                    <!-- Тип партнера -->
                    <TextBlock Text="Тип партнера" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbPartnerType" 
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Margin="0,0,0,12"/>

                    <!-- Наименование компании -->
                    <TextBlock Text="Наименование компании" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtCompanyName" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Юридический адрес -->
                    <TextBlock Text="Юридический адрес" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtLegalAddress" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"
                             TextWrapping="Wrap"/>

                    <!-- ИНН -->
                    <TextBlock Text="ИНН" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtInn" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"
                             MaxLength="12"/>

                    <!-- ФИО директора -->
                    <TextBlock Text="ФИО директора" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtDirectorName" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtPhone" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtEmail" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,12"/>

                    <!-- Рейтинг -->
                    <TextBlock Text="Рейтинг" 
                               FontWeight="Bold" 
                               Foreground="#666666" 
                               Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtRating" 
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,5"
                             PreviewTextInput="TxtRating_PreviewTextInput"/>

                    <TextBlock Text="* обязательные поля" 
                               Foreground="#F44336" 
                               FontSize="11"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,10,0,0">
                <Button x:Name="BtnSave" 
                        Content="💾 Сохранить" 
                        Width="100"
                        Background="#4CAF50"
                        Style="{StaticResource ModernButtonStyle}"
                        Click="BtnSave_Click"
                        Margin="0,0,8,0"/>
                <Button x:Name="BtnCancel" 
                        Content="✖ Отмена" 
                        Width="90"
                        Background="#F44336"
                        Style="{StaticResource ModernButtonStyle}"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>