<Window x:Class="MasterPol.WPF.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="История продаж" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Эффект тени как отдельный ресурс -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" Opacity="0.15" ShadowDepth="3" Color="#333333"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="5" Opacity="0.2" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="350"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и информация о партнере -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="15" 
                Padding="20" 
                Margin="0,0,0,15"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock x:Name="TxtPartnerName" 
                           FontSize="26" FontWeight="Bold"
                           Text="История продаж"
                           Foreground="#333333"/>
                <TextBlock x:Name="TxtTotalSales" 
                           FontSize="18" 
                           Foreground="#4CAF50"
                           FontWeight="Bold"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Кнопка добавления продажи -->
        <Button x:Name="BtnAddSale" 
                Grid.Row="1"
                Content="➕ Добавить продажу" 
                Width="160" Height="35"
                Click="BtnAddSale_Click"
                Style="{StaticResource ModernButtonStyle}"
                HorizontalAlignment="Left"
                Margin="0,0,0,15"/>

        <!-- Таблица продаж -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="15" 
                Padding="10" 
                Margin="0,0,0,15"
                Effect="{StaticResource CardShadow}">
            <DataGrid x:Name="SalesGrid" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="#F8F9FA"
                      AlternatingRowBackground="#E9ECEF"
                      FontSize="12">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="35"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.Name}" Width="250"/>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding Product.Article}" Width="100"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="70"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Product.MinPartnerPrice, StringFormat={}{0:N2} ₽}" Width="100"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N2} ₽}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Круговая диаграмма -->
        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="15" 
                Padding="15"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📊 Распределение продаж по товарам" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#333333"
                           Margin="0,0,0,10"/>

                <lvc:PieChart x:Name="SalesPieChart" Grid.Row="1" LegendLocation="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>