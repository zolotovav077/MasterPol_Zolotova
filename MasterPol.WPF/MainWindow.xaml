<Window x:Class="MasterPol.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MasterPol.WPF"
        Title="Мастер Пол - Управление партнерами" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Конвертер для цвета скидки -->
        <local:DiscountToColorConverter x:Key="DiscountToColorConverter"/>

        <!-- Эффект тени как отдельный ресурс -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" Opacity="0.15" ShadowDepth="3" Color="#333333"/>

        <!-- Стиль для карточки партнера -->
        <Style x:Key="PartnerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="10" 
                Padding="15" 
                Margin="0,0,0,15"
                Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnAddPartner" 
                        Content="➕ Новый" 
                        Width="90" Height="38"
                        Click="BtnAddPartner_Click"
                        Background="#4CAF50"
                        FontWeight="Bold"
                        Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button x:Name="BtnRefresh" 
                        Content="🔄 Обн." 
                        Width="80" Height="38"
                        Click="BtnRefresh_Click"
                        Background="#2196F3"
                        FontWeight="Bold"
                        Cursor="Hand"/>
                <TextBlock x:Name="TxtStatus" 
                           VerticalAlignment="Center" 
                           Margin="20,0,0,0"
                           Foreground="#666666"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- Список партнеров -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            <ItemsControl x:Name="PartnersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PartnerCardStyle}" 
                                MouseLeftButtonDown="PartnerCard_MouseLeftButtonDown"
                                Tag="{Binding Id}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Информация о партнере -->
                                <StackPanel Grid.Row="0" Grid.Column="0" 
                                          Orientation="Horizontal" Margin="0,0,20,0">
                                    <Border Background="#E3F2FD" 
                                            CornerRadius="8" 
                                            Padding="8,3">
                                        <TextBlock Text="{Binding PartnerType.Name}" 
                                                   FontWeight="Bold" 
                                                   Foreground="#1976D2"
                                                   FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="{Binding CompanyName}" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" 
                                          Orientation="Horizontal">
                                    <TextBlock Text="👤" Foreground="#666666" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding DirectorName}" 
                                               Margin="0,0,20,0"
                                               Foreground="#333333"/>

                                    <TextBlock Text="📞" Foreground="#666666" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding Phone}" 
                                               Margin="0,0,20,0"
                                               Foreground="#333333"/>

                                    <TextBlock Text="✉️" Foreground="#666666" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding Email}" 
                                               Foreground="#333333"/>
                                </StackPanel>

                                <!-- Рейтинг и скидка -->
                                <StackPanel Grid.Row="0" Grid.Column="2" 
                                          Orientation="Horizontal">
                                    <Border Background="#FFC107" 
                                            CornerRadius="12" 
                                            Padding="10,4" 
                                            Margin="0,0,8,0">
                                        <TextBlock Text="⭐" Foreground="White" FontWeight="Bold"/>
                                    </Border>

                                    <Border CornerRadius="12" 
                                            Padding="10,4"
                                            Background="{Binding Converter={StaticResource DiscountToColorConverter}}">
                                        <TextBlock x:Name="DiscountText" 
                                                   Text="{Binding DiscountText, FallbackValue=0%}"
                                                   Foreground="White" 
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <!-- Компактные кнопки действий -->
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" 
                                          Orientation="Horizontal" 
                                          HorizontalAlignment="Right" 
                                          Margin="0,10,0,0">
                                    <Button Content="📊 История" 
                                            Tag="{Binding Id}"
                                            Click="BtnHistory_Click"
                                            Background="#4CAF50" 
                                            Width="80"
                                            Height="28"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"/>
                                    <Button Content="✏️ Ред." 
                                            Tag="{Binding Id}"
                                            Click="BtnEdit_Click"
                                            Background="#FF9800" 
                                            Width="60"
                                            Height="28"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Margin="0,0,5,0"/>
                                    <Button Content="🗑️" 
                                            Tag="{Binding Id}"
                                            Click="BtnDelete_Click"
                                            Background="#F44336" 
                                            Width="40"
                                            Height="28"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Статусная строка -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="10" 
                Padding="10" 
                Margin="0,15,0,0"
                Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👥" Foreground="#666666" Margin="0,0,5,0"/>
                <TextBlock x:Name="TxtPartnerCount" Foreground="#333333" Margin="0,0,20,0"/>
                <TextBlock Text="🔌" Foreground="#666666" Margin="0,0,5,0"/>
                <TextBlock x:Name="TxtDbStatus" Foreground="#333333"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>